# Backend Environment Variables Template

# Copy these to your deployment platform's environment variables

# ==========================================
# DATABASE CONFIGURATION (CRITICAL)
# ==========================================

# PostgreSQL connection string (REQUIRED - no default)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Examples:
# Local: postgresql://postgres:postgres@localhost:5432/geofence?sslmode=disable
# Render: postgresql://user:pass@dpg-xyz.render.internal:5432/geofence?sslmode=require
# AWS RDS: postgresql://postgres:pass@db.xyz.us-east-1.rds.amazonaws.com:5432/geofence?sslmode=require
# DigitalOcean: postgresql://user:pass@db.ondigitalocean.com:25060/geofence?sslmode=require

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geofence?sslmode=disable


# ==========================================
# API SERVER CONFIGURATION
# ==========================================

# Port to listen on (default: 8080)
# Most hosting platforms override this to their default port
PORT=8080

# API key to seed into database on startup
# CHANGE THIS IMMEDIATELY in production!
# Generate with: openssl rand -hex 16
# Must match VITE_API_KEY in frontend
SEED_API_KEY=dev-secret-key-change-me


# ==========================================
# PRODUCTION EXAMPLES
# ==========================================

# Render.com Example:
# DATABASE_URL=postgresql://user_abc:password_xyz@dpg-xyz.render.internal:5432/geofence?sslmode=require
# PORT=8000
# SEED_API_KEY=a7f3d9e4c2b1f8a6e5d4c3b2a1f9e8d7

# AWS EC2 + RDS Example:
# DATABASE_URL=postgresql://postgres:YourPassword@geofence-db.c1xyz.us-east-1.rds.amazonaws.com:5432/geofence?sslmode=require
# PORT=8080
# SEED_API_KEY=a7f3d9e4c2b1f8a6e5d4c3b2a1f9e8d7

# Railway.app Example:
# DATABASE_URL=postgresql://postgres:railway@localhost:5432/railway
# PORT=8080
# SEED_API_KEY=a7f3d9e4c2b1f8a6e5d4c3b2a1f9e8d7


# ==========================================
# DEPLOYMENT PLATFORMS
# ==========================================
# Render: Web Service → Environment → Add above
# Railway: Deploy → Variables → Add above
# AWS EC2: Create .env file locally, docker-compose reads it
# Docker: Set with -e flag: docker run -e DATABASE_URL=... backend:latest
