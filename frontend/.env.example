# Frontend Environment Variables Template
# Copy this file to .env or .env.local and configure for your environment

# Backend API URL (point to your backend domain)
# Local development: http://localhost:8080
# Production (HTTP): http://your-backend.example.com
# Production (HTTPS): https://your-backend.example.com
VITE_API_URL=http://localhost:8080

# WebSocket URL (for live alerts)
# Local development: ws://localhost:8080
# Production (HTTP): ws://your-backend.example.com
# Production (HTTPS): wss://your-backend.example.com (IMPORTANT: use wss for HTTPS)
VITE_WS_URL=ws://localhost:8080

# API Key (must match SEED_API_KEY from backend)
# Development: dev-secret-key-change-me
# Production: generate secure key with: openssl rand -hex 16
VITE_API_KEY=dev-secret-key-change-me

# ==============================================
# PRODUCTION EXAMPLES
# ==============================================
# For Render.com backend:
# VITE_API_URL=https://geofence-backend-xyz.onrender.com
# VITE_WS_URL=wss://geofence-backend-xyz.onrender.com
# VITE_API_KEY=a7f3d9e4c2b1f8a6e5d4c3b2a1f9e8d7

# For AWS EC2 backend:
# VITE_API_URL=https://your-domain.com
# VITE_WS_URL=wss://your-domain.com
# VITE_API_KEY=a7f3d9e4c2b1f8a6e5d4c3b2a1f9e8d7

# ==============================================
# DEPLOYMENT INSTRUCTIONS
# ==============================================
# Vercel: Settings → Environment Variables → Add VITE_* variables
# Netlify: Site settings → Build & deploy → Environment → Add VITE_* variables
# Cloudflare Pages: Settings → Environment variables → Add VITE_* variables
